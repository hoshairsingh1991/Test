{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",

    "noEmitOnError": false,
    "skipLibCheck": true,
    "strict": false,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "outDir": "dist",
    "rootDir": "src"
  },
  "include": ["src"]
}
